// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // TODO: Add directUrl = env("DIRECT_URL") once DIRECT_URL is configured for migrations.
}

enum ProjectStatus {
  draft
  uploaded
  analyzing
  reviewed
  quoted
  failed
}

enum ObjectType {
  apartment
  house
  office
}

enum RoomType {
  living_room
  bedroom
  kitchen
  bathroom
  hallway
  office
  unknown
}

enum MaterialUnit {
  pcs
  m
  set
}

enum MaterialCategory {
  cable
  socket
  switch
  breaker
  box
  panel
  other
}

enum AnalysisStatus {
  pending
  success
  failed
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String?
  companyName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  settings     UserSettings?
  passwordResetTokens PasswordResetToken[]

  @@index([createdAt])
}

model UserSettings {
  id             String    @id @default(cuid())
  userId         String    @unique
  companyAddress String?
  companyCity    String?
  companyCountry String?
  companyTaxId   String?
  companyPhone   String?
  companyEmail   String?
  laborFactor    Decimal   @default(12) @db.Decimal(10, 2)
  currency       String    @default("EUR")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id             String           @id @default(cuid())
  userId         String
  name           String
  clientName     String?
  objectType     ObjectType
  areaM2         Float
  status         ProjectStatus    @default(draft)
  sourceFilePath String?
  previewPath    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms          Room[]
  materials      ProjectMaterial[]
  analyses       Analysis[]
  quote          Quote?

  @@index([userId, createdAt])
  @@index([userId, status])
}

model Room {
  id              String          @id @default(cuid())
  projectId       String
  name            String
  type            RoomType        @default(unknown)
  estimatedAreaM2 Float?
  confidence      Float?
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suggestion      RoomSuggestion?

  @@index([projectId, sortOrder])
  @@index([projectId, type])
}

model RoomSuggestion {
  id                String    @id @default(cuid())
  roomId            String    @unique
  suggestedSockets  Int       @default(0)
  suggestedSwitches Int       @default(0)
  suggestedLights   Int       @default(0)
  userSockets       Int?
  userSwitches      Int?
  userLights        Int?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Material {
  id           String            @id @default(cuid())
  code         String?           @unique
  name         String
  unit         MaterialUnit
  defaultPrice Decimal           @db.Decimal(10, 2)
  category     MaterialCategory
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  projectItems ProjectMaterial[]

  @@index([category])
}

model ProjectMaterial {
  id         String    @id @default(cuid())
  projectId  String
  materialId String
  quantity   Decimal   @db.Decimal(10, 2)
  unitPrice  Decimal   @db.Decimal(10, 2)
  totalPrice Decimal   @db.Decimal(10, 2)
  source     String    @default("rule")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  material   Material  @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([materialId])
  @@unique([projectId, materialId])
}

model Analysis {
  id                 String         @id @default(cuid())
  projectId          String
  provider           String
  rawResponseJson    Json?
  parsedResponseJson Json?
  status             AnalysisStatus @default(pending)
  errorMessage       String?
  createdAt          DateTime       @default(now())

  project            Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Quote {
  id           String    @id @default(cuid())
  projectId    String    @unique
  laborCost    Decimal   @db.Decimal(10, 2)
  materialCost Decimal   @db.Decimal(10, 2)
  subtotal     Decimal   @db.Decimal(10, 2)
  total        Decimal   @db.Decimal(10, 2)
  pdfPath      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
